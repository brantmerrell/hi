# Application
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hindi_app
SECRET_KEY=<generate-a-long-random-string>
FRONTEND_URL=http://localhost:5173

# AWS SES — magic link authentication emails
AWS_ACCESS_KEY_ID=<access-key>
AWS_SECRET_ACCESS_KEY=<secret-key>
AWS_SES_REGION=us-east-1
FROM_EMAIL=noreply@yourdomain.com

# Azure Translator — pipeline only (word alignment + translation)
AZURE_TRANSLATOR_KEY=<key>
AZURE_TRANSLATOR_REGION=eastus

# Google Cloud — pipeline only (text-to-speech audio generation)
GOOGLE_CLOUD_API_KEY=<key>
