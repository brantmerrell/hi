# Application
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hindi_app
SECRET_KEY=changeme-generate-a-long-random-string
FRONTEND_URL=http://localhost:5173

# Resend — required for magic link auth emails
RESEND_API_KEY=re_your_key_here
FROM_EMAIL=noreply@yourdomain.com

# Azure Translator — pipeline only (word alignment + translation)
AZURE_TRANSLATOR_KEY=your_key_here
AZURE_TRANSLATOR_REGION=eastus

# Google Cloud — pipeline only (text-to-speech audio generation)
GOOGLE_CLOUD_API_KEY=your_key_here
